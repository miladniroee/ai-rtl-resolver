{
  "manifest_version": 3,
  "name": "Ai Chatbot Dir Resolver",
  "version": "3.0",
  "description": "Sets correct direction for persian/arabic language on ai chatbots",
  "author": "Milad Niroee",
  "homepage_url": "https://github.com/miladniroee/ai-rtl-resolver",
  "browser_specific_settings": {
    "gecko": {
      "id": "mniroee@gmail.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://chat.deepseek.com/*","https://claude.ai/*"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["loadFonts.js", "chatgpt.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["loadFonts.js", "deepseek.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["loadFonts.js", "claude.js"],
      "run_at": "document_end"
    }
  ]
}
